{
  "functions": {
    "app/api/search/route.js": {
      "maxDuration": 300,
      "memory": 2048
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" },
        { "key": "X-Accel-Buffering", "value": "no" }
      ]
    }
  ]
}
